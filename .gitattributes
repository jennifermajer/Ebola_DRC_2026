# Track binary raw data blobs under Git LFS so the main repo stays small.
# Scoped to data/**/raw/ so the shapefile in data/shapefiles/ (also binary,
# but always needed at clone time for tools/lib/schema.py) stays in regular git.
data/*/raw/**/*.xlsx filter=lfs diff=lfs merge=lfs -text
data/*/raw/**/*.xlsx.zip filter=lfs diff=lfs merge=lfs -text
data/*/raw/**/*.zip filter=lfs diff=lfs merge=lfs -text
data/*/raw/**/*.xls filter=lfs diff=lfs merge=lfs -text
data/*/raw/**/*.pdf filter=lfs diff=lfs merge=lfs -text
data/*/raw/**/*.parquet filter=lfs diff=lfs merge=lfs -text
data/*/raw/**/*.gpkg filter=lfs diff=lfs merge=lfs -text
data/*/raw/**/*.tif filter=lfs diff=lfs merge=lfs -text
data/*/raw/**/*.tiff filter=lfs diff=lfs merge=lfs -text
